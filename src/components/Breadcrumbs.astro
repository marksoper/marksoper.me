---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  asHeading?: boolean;
}

const { items, asHeading = false } = Astro.props;
---

<nav aria-label="Breadcrumb" class={asHeading ? 'mb-4' : 'mb-2'}>
  <ol class={asHeading ? 'flex flex-wrap items-baseline gap-x-3 gap-y-1 text-3xl sm:text-4xl font-semibold leading-tight tracking-[-0.02em]' : 'flex items-center gap-1.5 text-sm text-[var(--color-text-muted)]'}>
    {items.map((item, i) => (
      <li class={asHeading ? 'flex items-baseline gap-3 min-w-0' : 'flex items-center gap-1.5'}>
        {i > 0 && <span class={asHeading ? 'select-none text-[var(--color-text-muted)] font-normal' : 'select-none'}>/</span>}
        {item.href ? (
          <a href={item.href} class={asHeading ? 'text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors duration-150 no-underline' : 'hover:text-[var(--color-accent)] transition-colors duration-150'}>
            {item.label}
          </a>
        ) : (
          asHeading ? (
            <h1 class="text-[var(--color-text)] min-w-0">
              {item.label}
            </h1>
          ) : (
            <span class="text-[var(--color-text)]">{item.label}</span>
          )
        )}
      </li>
    ))}
  </ol>
</nav>
