---
// Hero section — used on every page
interface Props {
  showPhoto?: boolean;
  useHeading?: boolean;
  showTagline?: boolean;
}

const { showPhoto = false, useHeading = false, showTagline = false } = Astro.props;
---

<section class={`hero-section max-w-[var(--container-wide)] mx-auto px-[var(--spacing-page)] pt-[82px] w-full ${showTagline ? 'pb-8 sm:pb-12' : 'pb-4 sm:pb-5'}`}>
  <div class={showPhoto ? 'flex flex-col sm:flex-row gap-8 items-start' : 'flex flex-col sm:flex-row sm:items-start sm:justify-between gap-5'}>
      {showPhoto && (
        <a href="/">
          <img
            src="/img/mark_soper.png"
            alt="Mark Soper"
            class="photo-ring w-28 h-28 sm:w-36 sm:h-36 rounded-full object-cover shrink-0 ring-2 transition-all duration-300 hover:scale-105"
          />
        </a>
      )}

      <div class={showPhoto ? 'flex-1' : 'flex-1 min-w-0'}>
        <a href="/" class="no-underline">
          {useHeading ? (
            <h1 class="text-2xl sm:text-3xl font-semibold mb-1">Mark Soper</h1>
          ) : (
            <p class="text-2xl sm:text-3xl font-semibold mb-1 text-[var(--color-text)]">Mark Soper</p>
          )}
        </a>
        {showTagline && (
          <p class={showPhoto ? 'text-lg text-[var(--color-text-secondary)] mb-2' : 'text-base sm:text-lg text-[var(--color-text-secondary)]'}>
            Builder of data, cloud, and AI infrastructure products
          </p>
        )}
        {showPhoto && (
          <div class="mt-5">
            <button
              id="contact-toggle"
              class="btn-contact inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg active:scale-95 transition-all duration-150 cursor-pointer"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0l-9.75 6.093L2.25 6.75"/></svg>
              Contact me
            </button>
          </div>
        )}
      </div>

      <div class={showPhoto ? '' : 'sm:shrink-0'}>
        <div class="flex items-center gap-4">
          <a href="https://linkedin.com/in/marksoper" class="hover:scale-110 transition-all duration-150" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://github.com/marksoper" class="hover:scale-110 transition-all duration-150" target="_blank" rel="noopener" aria-label="GitHub">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </a>
          <a href="https://x.com/marksoper" class="hover:scale-110 transition-all duration-150" target="_blank" rel="noopener" aria-label="X (Twitter)">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>

          <div class="divider-line h-5 w-px"></div>

          <a href="/blog" class="blog-link text-lg transition-colors duration-150 font-medium">
            Blog
          </a>
        </div>

      </div>
  </div>

  <!-- Inline contact form (homepage only, below hero header row) -->
  <div id="contact-form" class={showPhoto ? 'overflow-hidden max-h-0 opacity-0 transition-all duration-300 ease-in-out' : 'hidden'}>
    <form id="contact-form-el" class="mt-6 space-y-3 max-w-2xl">
      <div>
        <input type="text" name="name" placeholder="Your name" required
          class="w-full px-3 py-2 text-sm rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] focus:outline-none focus:ring-2 transition-shadow duration-150" />
      </div>
      <div>
        <input type="email" name="email" placeholder="Your email" required
          class="w-full px-3 py-2 text-sm rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] focus:outline-none focus:ring-2 transition-shadow duration-150" />
      </div>
      <div>
        <textarea name="message" placeholder="Message" rows="4" required
          class="w-full px-3 py-2 text-sm rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] focus:outline-none focus:ring-2 transition-shadow duration-150 resize-none"></textarea>
      </div>
      <div class="cf-turnstile" data-sitekey="0x4AAAAAACo3twr36d0ibBIH" data-theme="light" data-size="compact"></div>
      <div class="flex items-center gap-3">
        <button type="submit" id="contact-submit"
          class="btn-contact px-4 py-2 text-sm font-medium rounded-lg active:scale-95 transition-all duration-150 cursor-pointer">
          Send
        </button>
        <button type="button" id="contact-cancel"
          class="px-4 py-2 text-sm transition-colors duration-150 cursor-pointer text-[var(--color-text-muted)]">
          Cancel
        </button>
        <span id="contact-status" class="text-sm text-[var(--color-text-muted)]"></span>
      </div>
    </form>
  </div>
</section>

<script>
  const toggle = document.getElementById('contact-toggle');
  const formWrapper = document.getElementById('contact-form');
  const formEl = document.getElementById('contact-form-el');
  const cancel = document.getElementById('contact-cancel');
  const status = document.getElementById('contact-status');
  const submitBtn = document.getElementById('contact-submit');

  let turnstileLoaded = false;
  function loadTurnstile() {
    if (turnstileLoaded) return;
    turnstileLoaded = true;
    const script = document.createElement('script');
    script.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
    script.async = true;
    document.head.appendChild(script);
  }

  function openForm() {
    loadTurnstile();
    formWrapper.style.maxHeight = formWrapper.scrollHeight + 200 + 'px';
    formWrapper.style.opacity = '1';
    toggle.style.display = 'none';
  }

  function closeForm() {
    formWrapper.style.maxHeight = '0';
    formWrapper.style.opacity = '0';
    toggle.style.display = '';
    status.textContent = '';
  }

  toggle.addEventListener('click', openForm);
  cancel.addEventListener('click', closeForm);

  formEl.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    status.textContent = '';

    try {
      const data = new FormData(formEl);
      const resp = await fetch('https://marksoper.me/api/contact', {
        method: 'POST',
        body: data,
      });
      const result = await resp.json();

      if (resp.ok) {
        status.style.color = '#16a34a';
        status.textContent = result.message || 'Sent!';
        formEl.reset();
        if (window.turnstile) turnstile.reset();
        setTimeout(closeForm, 3000);
      } else {
        status.style.color = '#dc2626';
        status.textContent = result.error || 'Something went wrong.';
      }
    } catch (err) {
      status.style.color = '#dc2626';
      status.textContent = 'Network error. Please try again.';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send';
    }
  });
</script>
