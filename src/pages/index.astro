---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { projects } from '../data/projects';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const currentProjects = projects.filter(p => p.current);
const pastProjects = projects.filter(p => !p.current);
---

<Base title="Mark Soper — Product Leader, Engineer, Entrepreneur">

  <script>
    // Slowly rotate the body gradient angle
    const body = document.querySelector('.body-gradient');
    if (body) {
      let start = performance.now();
      function tick(now) {
        const t = (now - start) / 1000;
        const bodyAngle = 140 + 10 * Math.sin(t * 2 * Math.PI / 50);
        body.style.setProperty('--body-grad-angle', bodyAngle + 'deg');
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }
  </script>
  <div class="max-w-[var(--container-wide)] mx-auto px-[var(--spacing-page)]">

    <!-- Work -->
    <section id="work" class="py-12">
      {/* Current projects */}
      <div class="space-y-1">
        {currentProjects.map(project => (
          <a
            href={`/work/${project.slug}/`}
            class="group flex items-center gap-4 py-3 px-3 -mx-3 rounded-lg no-underline transition-all duration-150 bg-[var(--color-accent)]/[0.04] hover:bg-[var(--color-accent)]/[0.07]"
          >
            {/* Icon */}
            <div class="w-10 h-10 shrink-0 rounded-lg overflow-hidden bg-[var(--color-surface-alt)] flex items-center justify-center">
              {(project.icon || project.logo) ? (
                <img
                  src={project.icon || project.logo}
                  alt={`${project.company}`}
                  class="w-7 h-7 object-contain"
                />
              ) : project.screenshot ? (
                <img
                  src={project.screenshot}
                  alt={`${project.company}`}
                  class="w-full h-full object-cover"
                />
              ) : (
                <span class="text-sm font-semibold text-[var(--color-text-muted)]">
                  {project.company.charAt(0)}
                </span>
              )}
            </div>

            {/* Info */}
            <div class="flex-1 min-w-0">
              <p class="leading-snug line-clamp-1">
                <span class="font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">{project.company}</span>
                <span class="text-xs text-[var(--color-text-muted)]"> &middot; {project.role}</span>
                <span class="font-[var(--font-mono)] text-xs text-[var(--color-text-muted)]"> {project.years}</span>
                <span class="text-sm text-[var(--color-text-secondary)]"> — {project.description}</span>
              </p>
            </div>

            {/* Arrow */}
            <svg class="w-4 h-4 text-[var(--color-text-muted)] opacity-0 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
          </a>
        ))}
      </div>

      {/* Past work */}
      <h2 class="font-[var(--font-mono)] text-xs tracking-widest uppercase text-[var(--color-text-muted)] mt-10 mb-4">
        Past work
      </h2>
      <div class="space-y-1">
        {pastProjects.map(project => (
          <a
            href={`/work/${project.slug}/`}
            class="group flex items-center gap-4 py-3 px-3 -mx-3 rounded-lg no-underline transition-all duration-150 hover:bg-[var(--color-surface-alt)]"
          >
            {/* Icon */}
            <div class="w-10 h-10 shrink-0 rounded-lg overflow-hidden bg-[var(--color-surface-alt)] flex items-center justify-center">
              {(project.icon || project.logo) ? (
                <img
                  src={project.icon || project.logo}
                  alt={`${project.company}`}
                  class="w-7 h-7 object-contain"
                />
              ) : project.screenshot ? (
                <img
                  src={project.screenshot}
                  alt={`${project.company}`}
                  class="w-full h-full object-cover"
                />
              ) : (
                <span class="text-sm font-semibold text-[var(--color-text-muted)]">
                  {project.company.charAt(0)}
                </span>
              )}
            </div>

            {/* Info */}
            <div class="flex-1 min-w-0">
              <p class="leading-snug line-clamp-1">
                <span class="font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">{project.company}</span>
                <span class="text-xs text-[var(--color-text-muted)]"> &middot; {project.role}</span>
                <span class="font-[var(--font-mono)] text-xs text-[var(--color-text-muted)]"> {project.years}</span>
                <span class="text-sm text-[var(--color-text-secondary)]"> — {project.description}</span>
              </p>
            </div>

            {/* Arrow */}
            <svg class="w-4 h-4 text-[var(--color-text-muted)] opacity-0 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
          </a>
        ))}
      </div>
    </section>

    <!-- Writing -->
    <section class="py-12">
      <h2 class="font-[var(--font-mono)] text-xs tracking-widest uppercase text-[var(--color-text-muted)] mb-6">
        Writing
      </h2>
      <div class="divide-y divide-[var(--color-border-light)]">
        {posts.map(post => (
          <a href={`/blog/${post.id}/`} class="flex justify-between items-baseline py-4 no-underline group">
            <span class="text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors font-medium">
              {post.data.title}
            </span>
            <span class="font-[var(--font-mono)] text-xs text-[var(--color-text-muted)] ml-4 shrink-0">
              {post.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
            </span>
          </a>
        ))}
      </div>
      <a href="/blog" class="inline-block mt-6 text-sm text-[var(--color-accent)] no-underline hover:underline">
        All posts &rarr;
      </a>
    </section>

  </div>
</Base>

